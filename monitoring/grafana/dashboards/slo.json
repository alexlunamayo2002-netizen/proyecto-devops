{
  "dashboard": {
    "title": "PetClinic SLO Dashboard",
    "panels": [
      {
        "title": "Request Rate (req/s)",
        "type": "timeseries",
        "targets": [{"expr": "rate(http_server_requests_seconds_count[5m])"}],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
      },
      {
        "title": "Error Rate (5xx %)",
        "type": "timeseries",
        "targets": [{"expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m]) / rate(http_server_requests_seconds_count[5m]) * 100"}],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
      },
      {
        "title": "Response Time P99 (ms)",
        "type": "timeseries",
        "targets": [{"expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket[5m])) * 1000"}],
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8}
      },
      {
        "title": "Pod Count",
        "type": "stat",
        "targets": [{"expr": "count(kube_pod_info{namespace=\"default\", pod=~\"petclinic.*\"})"}],
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8}
      }
    ],
    "time": {"from": "now-1h", "to": "now"},
    "refresh": "10s"
  }
}
